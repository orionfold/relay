#cloud-config
# Generated by the same-version relay-host-playbook CLI. This payload contains
# public bootstrap inputs only. Never add a license, password, token, API key,
# recovery key, provider credential, or customer data.
hostname: __HOSTNAME__
manage_etc_hosts: true
disable_root: true
ssh_pwauth: false
users:
  - name: relayadmin
    gecos: Relay Host operator
    groups: [adm, sudo]
    sudo: ["ALL=(ALL) NOPASSWD:ALL"]
    shell: /bin/bash
    lock_passwd: true
    ssh_authorized_keys:
      - __SSH_PUBLIC_KEY__
write_files:
  - path: /usr/local/sbin/relay-host-bootstrap
    owner: root:root
    permissions: "0755"
    encoding: b64
    content: __BOOTSTRAP_BASE64__
  - path: /etc/relay-host-portable.env
    owner: root:root
    permissions: "0644"
    content: |
      RELAY_VERSION=__RELAY_VERSION__
      CELL_IMAGE=__CELL_IMAGE__
      NODE_VERSION=__NODE_VERSION__
      NODE_ARCHIVE_SHA256=__NODE_ARCHIVE_SHA256__
      COSIGN_VERSION=__COSIGN_VERSION__
      COSIGN_SHA256=__COSIGN_SHA256__
runcmd:
  - [bash, -lc, "printf '%s  %s\\n' '__BOOTSTRAP_SHA256__' /usr/local/sbin/relay-host-bootstrap | sha256sum -c -"]
  - [/usr/local/sbin/relay-host-bootstrap]
final_message: "Relay Host bootstrap finished. Verify /var/lib/relay-host-portable/bootstrap.json before protected activation."
